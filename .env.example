# ─────────────────────────────────────────────────────────────────────────────
# URLMonitor — variables de entorno de producción
# Copia este archivo a .env y ajusta los valores antes de iniciar los servicios
# NUNCA subas .env a git
# ─────────────────────────────────────────────────────────────────────────────

# Django
SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria-minimo-50-chars
DEBUG=False
ALLOWED_HOSTS=urlmonitor.xyz www.urlmonitor.xyz
CSRF_TRUSTED_ORIGINS=https://urlmonitor.xyz https://www.urlmonitor.xyz
TIME_ZONE=Europe/Madrid

# PostgreSQL
DB_NAME=urlmonitor
DB_USER=urlmonitor
DB_PASSWORD=cambia-esta-password-segura
DB_HOST=db
DB_PORT=5432
